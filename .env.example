# AI Bro Detector — Vercel environment variables
# Copy this to .env.local for local dev (never commit .env.local)

# Required — Groq API key
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Optional — override the model (default: openai/gpt-oss-120b)
# MODEL_ID=openai/gpt-oss-120b

# CORS — space-separated extra origins (hubiyan.com subdomains + localhost are built in)
# ALLOWED_ORIGIN=

# Rate limit (5 analyses / 12h per IP) — Vercel KV (Dashboard → Storage → KV → link project)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# RATE_LIMIT_SALT=generate-a-long-random-string

# Whitelist — comma-separated IPs that get unlimited bro tokens (find yours at api.ipify.org)
# WHITELISTED_IPS=1.2.3.4,5.6.7.8

# Local testing — skip 5/12h bro-token limit (set in .env.local)
# DISABLE_RATE_LIMIT=true

# Vercel: add GROQ_API_KEY for Production and Development, then redeploy.
# Local: copy this file to .env.local, add GROQ_API_KEY, then from repo root run:
#   npm start
# Open http://localhost:3000/lab/ai-bro-detector/
