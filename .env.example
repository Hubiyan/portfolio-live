# AI Bro Detector — Vercel environment variables
# Copy this to .env.local for local dev (never commit .env.local)

# Required — Google AI Studio API key
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional — override the model (default: gemini-2.5-flash)
# MODEL_ID=gemini-2.0-flash

# CORS — space-separated extra origins (hubiyan.com subdomains + localhost are built in)
# ALLOWED_ORIGIN=

# Local full-stack: copy this file to .env.local, add GEMINI_API_KEY, then from repo root run:
#   npm run dev
# Open http://localhost:3000/lab/ai-bro-detector/ (port shown by Vercel if different).
